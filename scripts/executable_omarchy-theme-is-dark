#!/usr/bin/env bash
set -euo pipefail

theme_dir="${OMARCHY_THEME_DIR:-$HOME/.config/omarchy/current/theme}"
colors_file="${OMARCHY_THEME_COLORS_FILE:-$theme_dir/colors.toml}"
vscode_file="${OMARCHY_THEME_VSCODE_FILE:-$theme_dir/vscode.json}"

# Omarchy marks light themes explicitly.
if [[ -f "$theme_dir/light.mode" ]]; then
  exit 1
fi
if [[ -f "$theme_dir/dark.mode" ]]; then
  exit 0
fi

# Most Omarchy themes include vscode.json with a "type" field.
if [[ -r "$vscode_file" ]]; then
  case "$(sed -nE 's/^[[:space:]]*"type"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p' "$vscode_file" | head -n1 | tr '[:upper:]' '[:lower:]')" in
    dark) exit 0 ;;
    light) exit 1 ;;
  esac
fi

if [[ ! -r "$colors_file" ]]; then
  exit 2
fi

bg_hex="$(sed -nE 's/^background = "#?([0-9A-Fa-f]{6})".*/\1/p' "$colors_file" | head -n1)"
if [[ -z "$bg_hex" ]]; then
  exit 2
fi

r=$((16#${bg_hex:0:2}))
g=$((16#${bg_hex:2:2}))
b=$((16#${bg_hex:4:2}))

# Perceived brightness in range 0-255.
luma=$(((299 * r + 587 * g + 114 * b) / 1000))

if (( luma < 128 )); then
  exit 0
fi

exit 1
