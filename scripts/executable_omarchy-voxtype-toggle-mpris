#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/voxtype"
RESUME_FILE="$STATE_DIR/players_to_resume"

mkdir -p "$STATE_DIR"

get_voxtype_state() {
  voxtype status 2>/dev/null | tr -d '\r\n'
}

save_playing_players() {
  : > "$RESUME_FILE"

  if ! command -v playerctl >/dev/null 2>&1; then
    return 0
  fi

  # Capture only players currently in Playing state so we can restore intent.
  playerctl -a status --format '{{playerName}}|{{status}}' 2>/dev/null \
    | awk -F'|' '$2 == "Playing" {print $1}' \
    | sort -u > "$RESUME_FILE" || true
}

pause_music() {
  command -v playerctl >/dev/null 2>&1 || return 0
  playerctl -a pause >/dev/null 2>&1 || true
}

resume_music() {
  command -v playerctl >/dev/null 2>&1 || return 0
  [[ -f "$RESUME_FILE" ]] || return 0

  while IFS= read -r player; do
    [[ -n "$player" ]] || continue
    playerctl -p "$player" play >/dev/null 2>&1 || true
  done < "$RESUME_FILE"

  rm -f "$RESUME_FILE"
}

state="$(get_voxtype_state)"

if [[ "$state" == "recording" ]]; then
  voxtype record stop
  resume_music
else
  save_playing_players
  pause_music
  voxtype record start
fi
