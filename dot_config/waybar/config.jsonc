      "^Inkscape$": "у°ѓЈ",
      "^krita$": "у°ѓЈ",
      "^localsend$": "у°’Ќ",
      "^signal$": "у°­№",
      "^blender$": "у°‚«",
      "^brave\\-browser$": "у°€№",
