      "^BambuStudio$": "¾░å¦",
      "^FreeCAD$": "¾░╗¼",
      "^gimp$": "¾░āŻ",
      "^Inkscape$": "¾░āŻ",
      "^krita$": "¾░āŻ",
      "^localsend$": "¾░ÆŹ",
      "^signal$": "¾░Ł╣",
      "^blender$": "¾░é½",
      "^brave\\-browser$": "¾░ł╣",
